encryption = "gpg"
format = "yaml"
progress = true

[diff]
  command = "nvim"
  args = "-d"

[merge]
  command = "nvim"
  args = [
    "-d",
    "{{ .Destination }}",
    "{{ .Source }}",
    "{{ .Target }}"
  ]

